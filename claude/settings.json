{
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Task completed\" with title \"Claude Code\"'"
          },
          {
            "type": "command",
            "command": "claude-tmux-sync"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-tmux-sync"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude-tmux-sync"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Needs attention\" with title \"Claude Code\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$CLAUDE_CONFIG_DIR/statusline-command.sh"
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "skillify@claude-skillify": true,
    "sentry@claude-plugins-official": true,
    "my@my-plugin": true,
    "frontend-design@claude-plugins-official": true,
    "app@pbx": true
  },
  "extraKnownMarketplaces": {
    "claude-skillify": {
      "source": {
        "source": "github",
        "repo": "0xMH/claude-skillify"
      }
    },
    "my-plugin": {
      "source": {
        "source": "directory",
        "path": "/Users/brandon/dotfiles/my-plugin"
      }
    },
    "pbx": {
      "source": {
        "source": "directory",
        "path": "/Users/brandon/code/pbx"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
