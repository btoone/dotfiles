#!/usr/bin/env ruby
# frozen_string_literal: true

# === repo-heatmap ===
# A tracer-bullet "where is work happening" heatmap for a git repo.
#
# Reads `git log --numstat`, folds each file's churn into a recency-weighted
# "heat" score (recent changes glow, old ones fade via exponential decay), then
# renders a self-contained HTML treemap you can open in a browser. Files touched
# by AI (commits carrying a `Co-Authored-By: Claude` trailer) are tracked
# separately so you can see human vs AI attention at a glance.
#
# Unlike all-time churn (which just surfaces lockfiles and your oldest files),
# the recency decay answers "where is work happening *now*" — pick a short
# half-life and only the live work glows.
#
# === Usage ===
#   prototypes/repo-heatmap [REPO_PATH]      # defaults to current directory
#
#   HALF_LIFE_DAYS=7 prototypes/repo-heatmap ~/code/some-app
#
# Env knobs:
#   HALF_LIFE_DAYS  decay half-life in days (default 14) — smaller = more "now"
#   SINCE           git log --since window  (default "6 months ago")
#   OUT             output HTML path        (default a temp file, auto-opened)
#
# No gems, no services — `git log` is the database.

require "set"
require "time"
require "json"
require "tmpdir"

repo       = ARGV[0] || Dir.pwd
half_life  = (ENV["HALF_LIFE_DAYS"] || "14").to_f
since      = ENV["SINCE"] || "6 months ago"
out_path   = ENV["OUT"] || File.join(Dir.tmpdir, "repo-heatmap.html")

Dir.chdir(repo) do
  abort "Not a git repository: #{repo}" unless system("git rev-parse --git-dir > /dev/null 2>&1")

  # Files that currently exist — keeps the map to the live tree, drops the
  # noise from deleted/renamed paths.
  live = `git ls-files`.split("\n").to_set

  # Commits authored with AI help. Separate grep pass so the main numstat
  # parse below stays a clean two-shape stream (header lines + numstat lines).
  ai_commits = `git log --since="#{since}" -i --grep="Co-Authored-By: Claude" --format=%H`
                 .split("\n").to_set

  now = Time.now.to_f
  log = `git log --since="#{since}" --numstat --pretty=format:"@@@|%H|%at"`

  files = Hash.new { |h, k| h[k] = { heat: 0.0, churn: 0, ai_churn: 0, commits: 0, last: 0 } }

  current_weight = 0.0
  current_is_ai  = false
  current_time   = 0

  log.each_line do |line|
    line = line.chomp
    next if line.empty?

    if line.start_with?("@@@|")
      _, sha, at = line.split("|")
      current_time   = at.to_i
      age_days       = (now - current_time) / 86_400.0
      current_weight = 0.5**(age_days / half_life)
      current_is_ai  = ai_commits.include?(sha)
    else
      added, deleted, path = line.split("\t")
      next if added == "-" # binary file
      next unless live.include?(path)

      churn = added.to_i + deleted.to_i
      f = files[path]
      f[:heat]     += churn * current_weight
      f[:churn]    += churn
      f[:ai_churn] += churn if current_is_ai
      f[:commits]  += 1
      f[:last]      = current_time if current_time > f[:last]
    end
  end

  abort "No file activity found since '#{since}'." if files.empty?

  # Build a nested tree keyed by path segments for the treemap.
  root = { "name" => File.basename(File.expand_path(repo)), "children" => {} }
  files.each do |path, stat|
    node = root
    parts = path.split("/")
    parts.each_with_index do |part, i|
      if i == parts.length - 1
        ai_pct = stat[:churn].zero? ? 0 : (100.0 * stat[:ai_churn] / stat[:churn]).round
        (node["children"][part] ||= {}).merge!(
          "name"    => part,
          "heat"    => stat[:heat].round(2),
          "churn"   => stat[:churn],
          "ai_pct"  => ai_pct,
          "commits" => stat[:commits],
          "last"    => stat[:last]
        )
      else
        node = (node["children"][part] ||= { "name" => part, "children" => {} })
      end
    end
  end

  # Collapse the children-hashes into d3-friendly children-arrays.
  to_d3 = lambda do |node|
    kids = node["children"]
    if kids && !kids.empty?
      { "name" => node["name"],
        "children" => kids.values.map { |c| to_d3.call(c) } }
    else
      node.reject { |k, _| k == "children" }
    end
  end

  data = to_d3.call(root)
  max_heat = files.values.map { |s| s[:heat] }.max

  html = HTML_TEMPLATE
           .sub("__DATA__", JSON.generate(data))
           .sub("__MAX__", max_heat.round(2).to_s)
           .sub("__HALFLIFE__", half_life.to_s)
           .sub("__SINCE__", since)

  File.write(out_path, html)
  puts "Heatmap → #{out_path}"
  puts "Files: #{files.size}  Half-life: #{half_life}d  Since: #{since}"
  system("open", out_path) if RUBY_PLATFORM.include?("darwin")
end

BEGIN {
  HTML_TEMPLATE = <<~HTML
    <!doctype html>
    <html>
    <head>
      <meta charset="utf-8">
      <title>repo heatmap</title>
      <script src="https://cdn.jsdelivr.net/npm/d3@7"></script>
      <style>
        body { margin: 0; font: 13px -apple-system, system-ui, sans-serif;
               background: #0d1117; color: #c9d1d9; }
        header { padding: 12px 16px; border-bottom: 1px solid #21262d; }
        header b { color: #f0f6fc; }
        .sub { color: #8b949e; font-size: 12px; margin-top: 2px; }
        .legend { display: flex; gap: 16px; align-items: center; margin-top: 8px; font-size: 12px; }
        .swatch { width: 80px; height: 10px; border-radius: 2px;
                  background: linear-gradient(90deg, #161b22, #f85149); }
        .tile { stroke: #0d1117; stroke-width: 1px; cursor: default; }
        .label { fill: #c9d1d9; font-size: 10px; pointer-events: none; }
        .ai { fill: #58a6ff; }
        .toggle { display: inline-flex; }
        .toggle button { background: #161b22; color: #8b949e; border: 1px solid #30363d;
                         padding: 3px 12px; font: 12px inherit; cursor: pointer; }
        .toggle button:first-child { border-radius: 5px 0 0 5px; }
        .toggle button:last-child { border-radius: 0 5px 5px 0; border-left: none; }
        .toggle button.on { background: #1f6feb; color: #fff; border-color: #1f6feb; }
        #tip { position: fixed; pointer-events: none; background: #161b22;
               border: 1px solid #30363d; border-radius: 6px; padding: 8px 10px;
               font-size: 12px; opacity: 0; transition: opacity .1s; max-width: 260px; }
        #tip b { color: #f0f6fc; }
        #tip .row { color: #8b949e; }
        #tip .row span { color: #c9d1d9; }
      </style>
    </head>
    <body>
      <header>
        <b>Repo heatmap</b> — <span id="modeName">recency-weighted churn</span>
        <div class="sub">half-life __HALFLIFE__d · since "__SINCE__" · size = total churn · <span class="ai">◣</span> corner = AI-authored share (independent of color)</div>
        <div class="legend">
          <div class="toggle">
            <button id="btnHeat" class="on">recency</button><button id="btnAi">AI %</button>
          </div>
          <span id="legLo">cool</span><div class="swatch" id="swatch"></div><span id="legHi">hot</span>
        </div>
      </header>
      <svg id="chart"></svg>
      <div id="tip"></div>
      <script>
        const data = __DATA__;
        const MAX = __MAX__;

        const W = window.innerWidth, H = window.innerHeight - 88;
        const svg = d3.select("#chart").attr("width", W).attr("height", H);
        const tip = d3.select("#tip");

        const root = d3.hierarchy(data)
          .sum(d => d.churn || 0)
          .sort((a, b) => b.value - a.value);

        d3.treemap().size([W, H]).paddingInner(1).paddingTop(14).round(true)(root);

        // Two independent encodings, two color scales. Color shows ONE variable
        // at a time (toggle below); AI share rides a separate corner channel.
        const heatColor = d3.scaleSequential(d3.interpolateInferno).domain([0, MAX]);
        const aiColor   = d3.scaleSequential(d3.interpolateBlues).domain([-20, 100]);
        let mode = "heat";
        const colorFor = d => mode === "heat"
          ? heatColor(d.data.heat || 0)
          : aiColor(d.data.ai_pct || 0);

        const leaves = root.leaves();
        const cell = svg.selectAll("g").data(leaves).join("g")
          .attr("transform", d => `translate(${d.x0},${d.y0})`);

        const tiles = cell.append("rect")
          .attr("class", "tile")
          .attr("width", d => Math.max(0, d.x1 - d.x0))
          .attr("height", d => Math.max(0, d.y1 - d.y0))
          .attr("fill", colorFor)
          .on("mousemove", (e, d) => {
            const ago = d.data.last ? Math.round((Date.now()/1000 - d.data.last)/86400) : "?";
            tip.style("opacity", 1)
               .style("left", (e.clientX + 12) + "px")
               .style("top", (e.clientY + 12) + "px")
               .html(`<b>${d.ancestors().reverse().slice(1).map(a=>a.data.name).join("/")}</b>
                      <div class="row">churn: <span>${d.data.churn}</span> lines · ${d.data.commits} commits</div>
                      <div class="row">AI: <span>${d.data.ai_pct}%</span> · last touched <span>${ago}d</span> ago</div>`);
          })
          .on("mouseout", () => tip.style("opacity", 0));

        // Directory labels.
        svg.selectAll(".dir").data(root.descendants().filter(d => d.depth && d.children))
          .join("text").attr("class", "label")
          .attr("x", d => d.x0 + 3).attr("y", d => d.y0 + 10)
          .text(d => d.data.name);

        // Leaf labels where they fit.
        cell.filter(d => (d.x1 - d.x0) > 42 && (d.y1 - d.y0) > 14)
          .append("text").attr("class", "label")
          .attr("x", 3).attr("y", 11)
          .text(d => d.data.name);

        // AI share as an independent channel: a blue corner triangle whose
        // opacity scales with AI-authored %. Lets the heat color stay pure.
        cell.filter(d => (d.data.ai_pct || 0) > 0 && (d.x1 - d.x0) > 10 && (d.y1 - d.y0) > 10)
          .append("path")
          .attr("d", d => {
            const w = d.x1 - d.x0, s = Math.min(16, w * 0.4);
            return `M${w - s},0 L${w},0 L${w},${s} Z`;
          })
          .attr("fill", "#58a6ff")
          .attr("opacity", d => 0.2 + 0.8 * (d.data.ai_pct / 100))
          .attr("pointer-events", "none");

        // Toggle: recolor every tile and swap the legend between the two scales.
        const swatch = document.getElementById("swatch");
        function setMode(m) {
          mode = m;
          tiles.attr("fill", colorFor);
          document.getElementById("btnHeat").classList.toggle("on", m === "heat");
          document.getElementById("btnAi").classList.toggle("on", m === "ai");
          document.getElementById("modeName").textContent =
            m === "heat" ? "recency-weighted churn" : "AI-authored share";
          if (m === "heat") {
            swatch.style.background = "linear-gradient(90deg, #000004, #bb3754, #fcffa4)";
            document.getElementById("legLo").textContent = "cool";
            document.getElementById("legHi").textContent = "hot";
          } else {
            swatch.style.background = "linear-gradient(90deg, #161b22, #58a6ff)";
            document.getElementById("legLo").textContent = "0% AI";
            document.getElementById("legHi").textContent = "100% AI";
          }
        }
        document.getElementById("btnHeat").onclick = () => setMode("heat");
        document.getElementById("btnAi").onclick = () => setMode("ai");
        setMode("heat");
      </script>
    </body>
    </html>
  HTML
}
