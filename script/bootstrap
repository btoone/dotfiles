#!/usr/bin/env bash

# Installs the prerequisites that install everything else: Homebrew and mise,
# plus the runtimes in mise.toml. Homebrew packages and editor plugins come
# later, from script/update, once script/setup has laid down the symlinks.
#
# Usage: script/bootstrap

set -e

BASE_DIR=$(basename "$PWD")
if [[ $BASE_DIR != 'dotfiles' ]]; then
  echo '--- ERROR: Must be in the project root to install. ---' ; exit 1
fi

echo "==> Checking for Homebrew..."
if ! command -v brew &> /dev/null; then
  echo "    Homebrew not found. Install it first: https://brew.sh"
  exit 1
fi

echo "==> Installing mise..."
if ! command -v mise &> /dev/null; then
  curl https://mise.run | sh
fi

echo "==> Installing runtimes via mise..."
mise install

echo ""
echo "Done. Now run: just setup (or: script/setup && script/update)"
