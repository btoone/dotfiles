#!/usr/bin/env bash

# Value of BASE_DIR is "dotfiles". The README instructs the user to run
# `script/setup` and errors if called from another location.
BASE_DIR=$(basename "$PWD")

# Confirm we're installing from the project root
if [[ $BASE_DIR != 'dotfiles' ]]; then
  echo '--- ERROR: Must be in the project root to install. ---' ; exit 1
fi

echo "
=================
   PRE INSTALL
=================

1. Install Homebrew
2. Install packages: brew bundle --global
"

__results="
Summary:
"

# Install dotfiles
readonly MANIFEST='MANIFEST'
readonly TEMPLATES_DIR="$PWD/templates"

while read -r f
do
  ln -sf "$PWD/$f" "$HOME/.$f"
done < "$MANIFEST"
__results+="\n* Created symlink for each dotfiles listed in MANIFEST"

for file in "$TEMPLATES_DIR"/*; do
  filename=$(basename "$file")
  # Skip non-dotfile templates (e.g. claude-settings.local.json)
  [[ "$filename" == claude-* ]] && continue
  if [ ! -f "$HOME/.$filename" ]; then
    cp "$file" "$HOME/.$filename"
  fi
done
__results+="\n* Copied config templates from templates/ to $HOME (skipped existing)"

# Symlink tool scripts into ~/.local/bin (already on PATH via zshrc)
mkdir -p "$HOME/.local/bin"
for script in "$PWD"/tools/*; do
  ln -sf "$script" "$HOME/.local/bin/$(basename "$script")"
done
__results+="\n* Linked tool scripts from tools/ into ~/.local/bin"

# Claude Code config (special case: ~/.claude has runtime data, so we symlink individual files)
# Deploy into each profile dir that exists (~/.claude-personal, ~/.claude-work)
# Falls back to ~/.claude if neither profile dir exists
claude_dirs=()
[ -d "$HOME/.claude-personal" ] && claude_dirs+=("$HOME/.claude-personal")
[ -d "$HOME/.claude-work" ] && claude_dirs+=("$HOME/.claude-work")
[ ${#claude_dirs[@]} -eq 0 ] && claude_dirs=("$HOME/.claude")

for cdir in "${claude_dirs[@]}"; do
  mkdir -p "$cdir"
  ln -sf "$PWD/claude/statusline-command.sh" "$cdir/statusline-command.sh"
  ln -sfn "$PWD/claude/project-templates" "$cdir/project-templates"
  ln -sf "$PWD/claude/settings.json" "$cdir/settings.json"
  if [ ! -f "$cdir/settings.local.json" ]; then
    cp "$PWD/templates/claude-settings.local.json" "$cdir/settings.local.json"
  fi
done
__results+="\n* Linked Claude Code config (settings, statusline, project-templates) into ${claude_dirs[*]}"

# Install TMUX plugin manager
if [ ! -d "$HOME/.tmux/plugins" ]; then
  git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
  __results+="\n* Installed Tmux Plugin Manager \"~/.tmux/plugins/tpm\""
fi

# Vim plugins are managed by vim-plug and installed on first launch

# Initialize mise and install runtimes from tool-versions
if command -v mise &> /dev/null; then
  echo "→ Installing mise runtimes from tool-versions..."
  mise install
  __results+="\n* Installed mise runtimes from tool-versions"
else
  __results+="\n* Skipped mise setup (not installed - run 'brew bundle --global' first)"
fi

# Prompt user to load new environment
__results+="
=================
   NEXT STEPS
=================

1. Start a new terminal session (or run 'exec zsh' to reload)
2. In tmux: prefix + I to install plugins
3. In vim: :PlugInstall to install plugins
4. Set terminal font to \"Hack Nerd Font\" for status bar icons
"

echo -e "$__results"
exit 0
