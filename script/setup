#!/usr/bin/env bash

# Configures the local environment by symlinking dotfiles, deploying tool
# scripts, and copying config templates. Fast, idempotent, no network needed.
#
# Usage: script/setup

BASE_DIR=$(basename "$PWD")
if [[ $BASE_DIR != 'dotfiles' ]]; then
  echo '--- ERROR: Must be in the project root to install. ---' ; exit 1
fi

__results="
Summary:
"

# Symlink dotfiles listed in MANIFEST
readonly MANIFEST='MANIFEST'
while read -r f; do
  ln -sfn "$PWD/$f" "$HOME/.$f"
done < "$MANIFEST"
__results+="\n* Symlinked dotfiles from MANIFEST"

# Copy config templates (only if they don't already exist)
readonly TEMPLATES_DIR="$PWD/templates"
for file in "$TEMPLATES_DIR"/*; do
  filename=$(basename "$file")
  [[ "$filename" == claude-* ]] && continue
  if [ ! -f "$HOME/.$filename" ]; then
    cp "$file" "$HOME/.$filename"
  fi
done
__results+="\n* Copied config templates to \$HOME (skipped existing)"

# XDG config — symlink git ignore/attributes into ~/.config/git
mkdir -p "$HOME/.config/git"
ln -sf "$PWD/git/ignore" "$HOME/.config/git/ignore"
ln -sf "$PWD/git/attributes" "$HOME/.config/git/attributes"
__results+="\n* Linked git config into ~/.config/git"

# Symlink tool scripts into ~/.local/bin (on PATH via zshrc)
mkdir -p "$HOME/.local/bin"
for script in "$PWD"/tools/*; do
  ln -sf "$script" "$HOME/.local/bin/$(basename "$script")"
done
__results+="\n* Linked tool scripts into ~/.local/bin"

# Claude Code config — symlink into each profile dir that exists
claude_dirs=()
[ -d "$HOME/.claude-personal" ] && claude_dirs+=("$HOME/.claude-personal")
[ -d "$HOME/.claude-work" ] && claude_dirs+=("$HOME/.claude-work")

if [ ${#claude_dirs[@]} -eq 0 ]; then
  echo ""
  echo "No Claude Code profile directory found (~/.claude-personal or ~/.claude-work)."
  echo "Which profile should be set up as the default?"
  echo "  1) personal  (~/.claude-personal)"
  echo "  2) work      (~/.claude-work)"
  echo "  3) skip      (use ~/.claude for now)"
  printf "Choose [1/2/3]: "
  read -r claude_choice
  case "$claude_choice" in
    1)
      claude_dirs=("$HOME/.claude-personal")
      machine_type="personal"
      ;;
    2)
      claude_dirs=("$HOME/.claude-work")
      machine_type="work"
      ;;
    *)
      claude_dirs=("$HOME/.claude")
      machine_type=""
      ;;
  esac

  # Update ~/.zshrc.local with MACHINE_TYPE if the user picked a profile
  if [ -n "$machine_type" ] && [ -f "$HOME/.zshrc.local" ]; then
    sed -i '' "s|^# export MACHINE_TYPE=.*|export MACHINE_TYPE=$machine_type|" "$HOME/.zshrc.local"
    sed -i '' 's|^# export CLAUDE_CONFIG_DIR=|export CLAUDE_CONFIG_DIR=|' "$HOME/.zshrc.local"
  fi
fi

for cdir in "${claude_dirs[@]}"; do
  mkdir -p "$cdir"
  ln -sf "$PWD/claude/statusline-command.sh" "$cdir/statusline-command.sh"
  ln -sfn "$PWD/claude/project-templates" "$cdir/project-templates"
  ln -sf "$PWD/claude/settings.json" "$cdir/settings.json"
  mkdir -p "$cdir/skills"
  for skill in "$PWD"/claude/skills/*/; do
    ln -sfn "$skill" "$cdir/skills/$(basename "$skill")"
  done
  mkdir -p "$cdir/commands"
  for cmd_dir in "$PWD"/claude/commands/*/; do
    ln -sfn "$cmd_dir" "$cdir/commands/$(basename "$cmd_dir")"
  done
  if [ ! -f "$cdir/settings.local.json" ]; then
    cp "$PWD/templates/claude-settings.local.json" "$cdir/settings.local.json"
  fi
done
__results+="\n* Linked Claude Code config into ${claude_dirs[*]}"

# Install tmux plugin manager
if [ ! -d "$HOME/.tmux/plugins" ]; then
  git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
  __results+="\n* Installed tpm"
fi

__results+="
=================
   NEXT STEPS
=================

1. Start a new terminal session (or run 'exec zsh' to reload)
2. In tmux: prefix + I to install plugins
3. In vim: :PlugInstall to install plugins
4. Set terminal font to \"Hack Nerd Font\" for status bar icons
5. For Claude Code: verify MACHINE_TYPE is set in ~/.zshrc.local
   (should already be configured if you chose a profile above)
"

echo -e "$__results"
