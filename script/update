#!/usr/bin/env bash

# Brings installed dependencies in line with the current checkout: Homebrew
# packages, vim plugins, tmux plugins. Run after pulling changes. Needs network.
#
# Usage: script/update

set -e

BASE_DIR=$(basename "$PWD")
if [[ $BASE_DIR != 'dotfiles' ]]; then
  echo '--- ERROR: Must be in the project root to install. ---' ; exit 1
fi

# The three installs are independent, so a failing one must not skip the rest —
# a silently unrun step is exactly how gutentags went missing for weeks.
failed=()

# Homebrew stopped bottling for macOS 13 and older, so every formula there
# compiles from source — hours per package, and pinned llvm blocks the Rust ones
# outright. NO_UPGRADE freezes what's installed but still builds anything the
# Brewfile adds later, so on those machines brew goes report-only: name the drift
# and let it be installed deliberately, if at all.
brew_report_only=false
if [[ $OSTYPE == darwin* ]] && (( $(sw_vers -productVersion | cut -d. -f1) < 14 )); then
  brew_report_only=true
  export HOMEBREW_BUNDLE_NO_UPGRADE=1 HOMEBREW_BUNDLE_NO_JOBS=1
  echo "==> macOS $(sw_vers -productVersion) has no Homebrew bottles: brew is report-only"
fi

echo "==> Installing Homebrew packages..."
if ! command -v brew &> /dev/null; then
  echo "    Homebrew not found. Install it first: https://brew.sh"
  failed+=("brew bundle")
elif [[ $brew_report_only == true ]]; then
  brew bundle check --global --verbose ||
    echo "    Anything missing compiles from source here. Install it deliberately: brew install <formula>"
else
  brew bundle --global || failed+=("brew bundle")
fi

# --sync so vim-plug finishes installing before +qa tears the session down
echo "==> Installing vim plugins..."
vim +'PlugInstall --sync' +'PlugClean!' +qa || failed+=("vim plugins")

echo "==> Installing tmux plugins..."
TPM_INSTALL="$HOME/.tmux/plugins/tpm/bin/install_plugins"
if [ -x "$TPM_INSTALL" ]; then
  "$TPM_INSTALL" || failed+=("tmux plugins")
else
  echo "    tpm not found. Run script/setup first."
  failed+=("tmux plugins")
fi

if [ ${#failed[@]} -gt 0 ]; then
  echo ""
  echo "--- FAILED: ${failed[*]} ---"
  echo "Fix the errors above and re-run script/update."
  exit 1
fi

# Last script in the chain, so the manual leftovers get printed here
cat <<'EOF'

=================
   NEXT STEPS
=================

1. Start a new terminal session (or run 'exec zsh' to reload)
2. Set terminal font to "Hack Nerd Font" for status bar icons
3. For Claude Code: verify MACHINE_TYPE is set in ~/.zshrc.local
   (set automatically if you chose a profile during script/setup)
4. For additional Claude Code profiles (e.g. switching between work/personal):
   claude plugins marketplace add ~/dotfiles/my-plugin
   claude plugins install my
EOF
