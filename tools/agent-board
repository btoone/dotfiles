#!/usr/bin/env bash
# fzf status board for Claude Code sessions, fed by agent-board-hook state
# files. Meant to run in a tmux popup (prefix + B).
#
#   enter   jump to the session's pane
#   ctrl-s  send a prompt into the session (canned list, or type your own)
#   ctrl-n  edit the session's note (📌 shown on the board and in the preview)
#   ctrl-t  toggle "on ice" (deliberately resting — sorts to its own lane)
#
# `agent-board --note <text>` from any pane attaches a note to the agent
# session in that tmux window (the cowsay-in-a-split workflow, upgraded).
#
# The list live-reloads while open: the hook POSTs to each board's fzf
# --listen port (registered as <state dir>/.port.<pid>). The preview pane
# shows the session's last assistant message straight from its transcript.
#
# The lane/glyph mapping lives here only — agent-board-hook delegates glyph
# updates via --window-glyph.

set -uo pipefail

# Notification clicks run this script under launchd's minimal PATH (no
# Homebrew, so no jq/tmux); appended rather than prepended so test stubs
# and user overrides still win
PATH="$PATH:/opt/homebrew/bin:/usr/local/bin"

board_dir="${AGENT_BOARD_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/agent-board}"
mkdir -p "$board_dir"
board_bin="${AGENT_BOARD_BIN:-$HOME/.local/bin/agent-board}"
# One port file per board instance so several boards (CLI + popups) all
# receive live reloads; the hook pokes every .port.* and prunes dead ones
port_file="$board_dir/.port.$$"

# Keep the user's interactive fzf defaults (previews, --tmux, etc.) out of the popup
fzf_clean() { FZF_DEFAULT_OPTS='' FZF_DEFAULT_OPTS_FILE='' fzf "$@"; }

prune_dead_sessions() {
  local live_panes f pane
  # A tmux failure (server restarting, no server) must not read as "no panes
  # exist" — that would wipe every state file, notes and all
  live_panes=$(tmux list-panes -a -F '#{pane_id}') || return 0
  [ -n "$live_panes" ] || return 0
  for f in "$board_dir"/*.json; do
    [ -e "$f" ] || continue
    pane=$(jq -r '.pane // empty' "$f")
    grep -qxF "$pane" <<<"$live_panes" || rm -f "$f"
  done
}

# The single copy of the lane/glyph tables: build_lines renders from it and
# refresh_window_glyph serves it to the hook
lane_glyph_jq='
  def lane:  if .on_ice then 3
             elif .state == "needs-permission" then 0
             elif .state == "needs-answer" then 1
             elif .state == "working" then 2
             else 4 end;
  def glyph: if .on_ice then "🧊"
             elif .state == "needs-permission" then "🔐"
             elif .state == "needs-answer" then "💬"
             elif .state == "working" then "🔄"
             else "✅" end;
'

# TSV: lane, updated_at, session_id, pane, window_id, tmux_session, display, note
build_lines() {
  local now f
  now=$(date +%s)
  for f in "$board_dir"/*.json; do
    [ -e "$f" ] || continue
    jq -r --argjson now "$now" "$lane_glyph_jq"'
      def age:   ($now - .updated_at) |
                 if . < 60 then "\(.)s"
                 elif . < 3600 then "\(. / 60 | floor)m"
                 else "\(. / 3600 | floor)h" end;
      [ (lane | tostring), (.updated_at | tostring),
        .session_id, .pane, .window_id, .tmux_session,
        "\(glyph) \(.tmux_session):\(.window_name)  [\(.cwd | sub(".*/"; ""))]  \(age)  \(.reason // "")",
        (.note // "")
      ] | @tsv
    ' "$f"
  done | sort -t$'\t' -k1,1n -k2,2nr
}

# build_lines plus a colored header row above each lane (empty session_id
# marks a header — every action guards on that). Emits NUL-delimited records
# for fzf --read0: a session with a note becomes a two-line item, the note
# indented on its own line so it never crowds out the status line.
build_board() {
  build_lines | awk -F'\t' '
    BEGIN {
      name[0] = "NEEDS PERMISSION"; color[0] = "\033[1;31m"
      name[1] = "NEEDS ANSWER";     color[1] = "\033[1;33m"
      name[2] = "WORKING";          color[2] = "\033[1;36m"
      name[3] = "ON ICE";           color[3] = "\033[1;35m"
      name[4] = "DONE";             color[4] = "\033[1;90m"
    }
    { rows[NR] = $0; lane[NR] = $1; cnt[$1]++ }
    END {
      prev = -1
      for (i = 1; i <= NR; i++) {
        if (lane[i] != prev) {
          printf "%s\t9999999999\t\t\t\t\t%s── %s (%d) ──\033[0m\1",
                 lane[i], color[lane[i]], name[lane[i]], cnt[lane[i]]
          prev = lane[i]
        }
        n = split(rows[i], f, "\t")
        line = f[1]
        for (j = 2; j <= 7; j++) line = line "\t" f[j]
        if (n >= 8 && f[8] != "")
          line = line "\n     \033[33m📌 " f[8] "\033[0m"
        printf "%s\1", line
      }
    }
  ' | tr '\001' '\000'
}

# Serialize state-file read-modify-writes against the hook (mkdir as mutex;
# mirrored in agent-board-hook). A crashed holder's lock is broken after ~1s;
# bail unlocked after ~2s rather than ever wedging.
lock_state() {
  local dir="$1.lock" tries=0
  until mkdir "$dir" 2>/dev/null; do
    tries=$((tries + 1))
    [ "$tries" -ge 50 ] && rm -rf "$dir"
    [ "$tries" -ge 100 ] && return 0
    sleep 0.02
  done
}
unlock_state() { rmdir "$1.lock" 2>/dev/null; }

# Sessions are per-pane but @agent_glyph is per-window: when several sessions
# share a window, show the most urgent lane; unset only when none remain.
refresh_window_glyph() {
  local win=$1 best f
  best=$(for f in "$board_dir"/*.json; do
    [ -e "$f" ] || continue
    jq -r --arg win "$win" "$lane_glyph_jq"'
      select(.window_id == $win) | "\(lane)\t\(glyph)"' "$f"
  done | sort -n | head -1 | cut -f2)
  if [ -n "$best" ]; then
    tmux set-window-option -t "$win" @agent_glyph "$best"
  else
    tmux set-window-option -t "$win" -u @agent_glyph
  fi
}

toggle_on_ice() {
  local f=$1 tmp
  lock_state "$f"
  tmp=$(mktemp "$f.XXXXXX")
  jq '.on_ice = (.on_ice | not)' "$f" > "$tmp" && mv "$tmp" "$f" || rm -f "$tmp"
  unlock_state "$f"
  refresh_window_glyph "$(jq -r '.window_id' "$f")"
  poke_boards
}

pick_prompt() {
  local canned out query sel
  canned=$'continue\nproceed with your recommendation\nrun the tests and fix any failures\ncommit this\nsummarize where you are and what is left'
  out=$(fzf_clean --print-query --layout=reverse-list --info=inline \
            --prompt='send prompt > ' \
            --header='pick a canned prompt, or type your own and hit enter' \
            <<<"$canned") || true
  query=$(sed -n 1p <<<"$out")
  sel=$(sed -n 2p <<<"$out")
  [ -n "${sel:-$query}" ] || return 1
  printf '%s' "${sel:-$query}"
}

# Tell every open board's fzf to reload. Registrations are pruned when their
# owning process is gone — never on curl failure, which may just be a busy
# board mid-keybinding. (Mirrored in agent-board-hook.)
poke_boards() {
  local pf pid
  for pf in "$board_dir"/.port.*; do
    [ -e "$pf" ] || continue
    [ "$pf" = "$port_file" ] && continue
    pid=${pf##*.}
    if ! kill -0 "$pid" 2>/dev/null; then
      rm -f "$pf"
      continue
    fi
    curl -s -m 1 -X POST "http://localhost:$(cat "$pf")" \
      -d "reload($board_bin --lines)" >/dev/null 2>&1 || true
  done
}

save_note() {
  local f=$1 text=$2 tmp
  lock_state "$f"
  tmp=$(mktemp "$f.XXXXXX")
  jq --arg note "$text" '.note = $note' "$f" > "$tmp" && mv "$tmp" "$f" || rm -f "$tmp"
  unlock_state "$f"
  poke_boards
}

# Tiny fzf-as-input-line editor, pre-filled with the current note.
# Enter saves (empty clears), esc keeps the current note.
edit_note() {
  local f="$board_dir/$1.json" current out
  [ -f "$f" ] || return 0
  current=$(jq -r '.note // ""' "$f")
  out=$(fzf_clean --print-query --query "$current" --info=hidden \
            --prompt='📌 note > ' \
            --header='edit the note — enter saves, empty clears, esc cancels' \
            </dev/null)
  [ $? -eq 130 ] && return 0
  save_note "$f" "$(sed -n 1p <<<"$out")"
}

# Attach a note to the agent session in the current tmux window — matched by
# window, not pane, since it's run from a shell split beside the agent.
note_current_window() {
  local text=$1 win f best
  win=$(tmux display-message -p '#{window_id}') || return 1
  best=$(for f in "$board_dir"/*.json; do
    [ -e "$f" ] || continue
    jq -r --arg win "$win" 'select(.window_id == $win) | "\(.updated_at)\t\(input_filename)"' "$f"
  done | sort -rn | head -1 | cut -f2)
  if [ -z "$best" ]; then
    echo "no agent session in this tmux window" >&2
    return 1
  fi
  save_note "$best" "$text"
  if [ -n "$text" ] && command -v cowsay >/dev/null; then
    cowsay "📌 $text"
  elif [ -n "$text" ]; then
    echo "📌 $text"
  else
    echo "note cleared"
  fi
}

# Focus a session's pane. Inside tmux, switches the current client; outside
# (e.g. clicking a notification), steers the most recently active client and
# brings iTerm forward.
jump_to() {
  local f="$board_dir/$1.json" pane window session client
  [ -f "$f" ] || return 0
  IFS=$'\t' read -r pane window session < <(jq -r '[.pane, .window_id, .tmux_session] | @tsv' "$f")
  tmux select-window -t "$window"
  tmux select-pane -t "$pane"
  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$session"
  else
    client=$(tmux list-clients -F '#{client_activity} #{client_name}' | sort -rn | head -1 | awk '{print $2}')
    [ -n "$client" ] && tmux switch-client -c "$client" -t "$session"
    open -a iTerm
  fi
}

show_preview() {
  local id=${1:-} f transcript note
  f="$board_dir/$id.json"
  { [ -n "$id" ] && [ -f "$f" ]; } || exit 0
  jq -r '"\(.state)\(if .on_ice then " · on ice" else "" end) · \(.tmux_session):\(.window_name)\n\(.cwd)"' "$f"
  note=$(jq -r '.note // empty' "$f")
  [ -n "$note" ] && printf '\n📌 %s\n' "$note" | fold -s -w "${FZF_PREVIEW_COLUMNS:-80}"
  echo
  transcript=$(jq -r '.transcript // empty' "$f")
  if [ -f "$transcript" ]; then
    echo "── last assistant message ──"
    grep '"type":"assistant"' "$transcript" | tail -1 |
      jq -r '[.message.content[]? | select(.type == "text") | .text] | join("\n")' |
      fold -s -w "${FZF_PREVIEW_COLUMNS:-80}"
  else
    echo "(no transcript recorded yet — restart this session to pick up the new hook)"
  fi
}

case "${1:-}" in
  --list)
    prune_dead_sessions
    build_lines
    exit 0
    ;;
  --lines)  # board format for fzf reloads (headers included)
    prune_dead_sessions
    build_board
    exit 0
    ;;
  --toggle)
    [ -n "${2:-}" ] && [ -f "$board_dir/$2.json" ] && toggle_on_ice "$board_dir/$2.json"
    exit 0
    ;;
  --send)
    [ -n "${2:-}" ] && [ -n "${3:-}" ] || exit 0
    if prompt=$(pick_prompt); then
      # -- so a prompt starting with a dash isn't parsed as flags; && so a
      # failed send never fires a bare Enter into the pane
      tmux send-keys -t "$3" -l -- "$prompt" &&
        tmux send-keys -t "$3" Enter
    fi
    exit 0
    ;;
  --preview)
    show_preview "${2:-}"
    exit 0
    ;;
  --jump)
    [ -n "${2:-}" ] && jump_to "$2"
    exit 0
    ;;
  --window-glyph)  # recompute @agent_glyph for a window (used by agent-board-hook)
    [ -n "${2:-}" ] && refresh_window_glyph "$2"
    exit 0
    ;;
  --edit-note)
    [ -n "${2:-}" ] && edit_note "$2"
    exit 0
    ;;
  --note)
    shift
    note_current_window "$*"
    exit $?
    ;;
esac

trap 'rm -f "$port_file"' EXIT

while true; do
  prune_dead_sessions
  if [ -z "$(build_lines)" ]; then
    echo "No Claude Code sessions on the board."
    sleep 2
    exit 0
  fi

  # build_board pipes straight in: $(...) would eat the NUL record separators
  sel=$(build_board | fzf_clean --ansi --read0 --delimiter=$'\t' --with-nth=7 --no-sort \
            --layout=reverse-list --info=inline \
            --listen --sync \
            --bind "start:pos(2)+execute-silent(echo \$FZF_PORT > $port_file)" \
            --bind "ctrl-t:execute-silent($0 --toggle {3})+reload($0 --lines)" \
            --bind "ctrl-s:execute($0 --send {3} {4})" \
            --bind "ctrl-n:execute($0 --edit-note {3})+reload($0 --lines)" \
            --preview "$0 --preview {3}" \
            --preview-window=right,45%,wrap \
            --prompt='agent board > ' \
            --header=$'enter: jump   ctrl-s: send prompt   ctrl-n: note   ctrl-t: toggle on ice' \
            ) || exit 0
  IFS=$'\t' read -r _ _ session_id _ <<<"$sel"
  [ -n "$session_id" ] || continue

  jump_to "$session_id"
  exit 0
done
