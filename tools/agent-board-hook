#!/usr/bin/env bash
# Claude Code hook: maintains one state file per session for the agent-board
# TUI, syncs the session title to the tmux window name, sets @agent_glyph on
# the window for ambient status, and raises blocked-session notifications.
# Wired into UserPromptSubmit, PreToolUse, PostToolUse, Notification, Stop,
# SessionEnd.
#
# State files live in ~/.local/state/agent-board/<session_id>.json.
# Lane/glyph logic is mirrored in agent-board — keep them in sync.

# Hooks must stay silent: UserPromptSubmit stdout is injected into context.
exec >/dev/null 2>&1

[ -n "${TMUX_PANE:-}" ] || exit 0

board_dir="${AGENT_BOARD_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/agent-board}"
mkdir -p "$board_dir"

input=$(cat /dev/stdin)
session_id=$(echo "$input" | jq -r '.session_id // empty')
[ -n "$session_id" ] || exit 0
event=$(echo "$input" | jq -r '.hook_event_name // empty')
cwd=$(echo "$input" | jq -r '.cwd // empty')
transcript=$(echo "$input" | jq -r '.transcript_path // empty')

IFS=$'\t' read -r tmux_session window_id window_name < <(
  tmux display-message -t "$TMUX_PANE" -p $'#{session_name}\t#{window_id}\t#W'
)
[ -n "$window_id" ] || exit 0

state_file="$board_dir/$session_id.json"

# Tell every open board's fzf to reload, pruning dead .port.* files
# (mirrored in agent-board)
poke_board() {
  local pf
  for pf in "$board_dir"/.port "$board_dir"/.port.*; do
    [ -e "$pf" ] || continue
    curl -s -m 1 -X POST "http://localhost:$(cat "$pf")" \
      -d "reload($HOME/.local/bin/agent-board --lines)" || rm -f "$pf"
  done
}

if [ "$event" = "SessionEnd" ]; then
  rm -f "$state_file"
  tmux set-window-option -t "$window_id" -u @agent_glyph
  poke_board
  exit 0
fi

# Window title from the transcript custom-title, else the sessions-index summary.
sync_window_title() {
  [ -f "$transcript" ] || return 0
  local title index
  title=$(grep '"custom-title"' "$transcript" | tail -1 | jq -r '.customTitle // empty')
  if [ -z "$title" ]; then
    index="$(dirname "$transcript")/sessions-index.json"
    if [ -f "$index" ]; then
      title=$(jq -r --arg id "$session_id" '.entries[] | select(.sessionId == $id) | .summary // empty' "$index")
    fi
  fi
  [ -z "$title" ] && return 0
  [ "$window_name" = "$title" ] && return 0
  tmux set-window-option -t "$window_id" automatic-rename off
  tmux rename-window -t "$window_id" "$title"
}

case "$event" in
  UserPromptSubmit|PostToolUse|Stop) sync_window_title ;;
esac

# PostToolUse exists for title sync only; PreToolUse already covers board state
[ "$event" = "PostToolUse" ] && exit 0

last_assistant_text() {
  [ -f "$transcript" ] || return 0
  grep '"type":"assistant"' "$transcript" | tail -1 |
    jq -r '[.message.content[]? | select(.type == "text") | .text] | join(" ") | gsub("\\s+"; " ")'
}

tail_chars() {
  local s=$1 n=$2
  if [ "${#s}" -gt "$n" ]; then printf '%s' "${s: -n}"; else printf '%s' "$s"; fi
}

state="" reason="" clear_on_ice=false

case "$event" in
  UserPromptSubmit)
    state="working"
    reason=$(echo "$input" | jq -r '.prompt // empty' | tr '\n\t' '  ' | head -c 80)
    clear_on_ice=true
    ;;
  PreToolUse)
    state="working"
    tool=$(echo "$input" | jq -r '.tool_name // empty')
    reason="using ${tool:-a tool}"
    ;;
  Notification)
    reason=$(echo "$input" | jq -r '.message // empty')
    case "$reason" in
      *permission*) state="needs-permission" ;;
      *)            state="needs-answer" ;;
    esac
    ;;
  Stop)
    text=$(last_assistant_text)
    if [[ "$(tail_chars "$text" 200)" == *\?* ]]; then
      state="needs-answer"
      reason=$(tail_chars "$text" 100)
    else
      state="done"
      reason="${text:0:80}"
    fi
    ;;
  *) exit 0 ;;
esac

on_ice=false
if [ "$clear_on_ice" = false ] && [ -f "$state_file" ]; then
  on_ice=$(jq -r '.on_ice // false' "$state_file")
  [ "$on_ice" = "true" ] || on_ice=false
fi

# User notes persist through every event; only the board clears them
note=""
[ -f "$state_file" ] && note=$(jq -r '.note // ""' "$state_file")

case "$state" in
  working)          glyph="🔄" ;;
  needs-answer)     glyph="💬" ;;
  needs-permission) glyph="🔐" ;;
  done)             glyph="✅" ;;
esac
[ "$on_ice" = "true" ] && glyph="🧊"

jq -n \
  --arg session_id "$session_id" \
  --arg cwd "$cwd" \
  --arg transcript "$transcript" \
  --arg pane "$TMUX_PANE" \
  --arg tmux_session "$tmux_session" \
  --arg window_id "$window_id" \
  --arg window_name "$window_name" \
  --arg state "$state" \
  --arg reason "$reason" \
  --arg note "$note" \
  --argjson on_ice "$on_ice" \
  --argjson updated_at "$(date +%s)" \
  '{$session_id, $cwd, $transcript, $pane, $tmux_session, $window_id, $window_name, $state, $reason, $note, $on_ice, $updated_at}' \
  > "$state_file.tmp" && mv "$state_file.tmp" "$state_file"

tmux set-window-option -t "$window_id" @agent_glyph "$glyph"
poke_board

# Blocked sessions get a clickable macOS banner (click jumps to the session).
# Deliberately NOT suppressed when the pane is active/visible: an active pane
# doesn't mean the user is at the keyboard.
if [ "$event" = "Notification" ] && command -v terminal-notifier >/dev/null; then
  terminal-notifier \
    -title "Claude Code" \
    -subtitle "$tmux_session · $(basename "$cwd")" \
    -message "$reason" \
    -group "agent-board-$session_id" \
    -execute "$HOME/.local/bin/agent-board --jump $session_id" || true
fi

exit 0
