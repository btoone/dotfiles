#!/usr/bin/env bash
# card-flipping CLI launcher. Wraps the project venv's `flip` Typer app.
# Invokes the venv python explicitly against the console script: this
# bypasses .venv/bin/flip's shebang (pinned to the iCloud-synced
# ~/Documents/... path, a sync-conflict risk) while keeping argv[0] as
# `flip` so --help renders the correct program name.

# Pin the data root so `flip` works from any cwd, not just the project
# dir. Respect an explicit override if the caller already set FLIP_ROOT
# (e.g. to point at a test copy).
export FLIP_ROOT="${FLIP_ROOT:-$HOME/Projects/card-flipping}"

venv="$HOME/Projects/card-flipping/.venv"
exec "$venv/bin/python" "$venv/bin/flip" "$@"
